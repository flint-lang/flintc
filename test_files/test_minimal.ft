use Core.print

variant CompilerToUse:
	C(void),
	DEV(void),
	TAG(str);

def print_c(CompilerToUse c):
	switch c:
		CompilerToUse.C():
			print("C\n");
		CompilerToUse.DEV():
			print("DEV\n");
		CompilerToUse.TAG(tag):
			print($"TAG: {tag}\n");

def main():
	CompilerToUse c = CompilerToUse.TAG("Hi there");
	print_c(c);
	print("Hello\n");

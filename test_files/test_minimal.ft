use Core.assert
use Core.print

def may_fail(bool fail) {ErrAssert}:
	print($"fail = {fail}\n");
	assert(not fail);

def main():
	fn<bool {ErrAssert}> f = ::may_fail;
	f(false) catch err:
		switch err:
			ErrAssert(e):
				print($"ErrAssert = {e}\n");
			anyerror(e):
				print($"anyerror = {e}\n");
	f(true) catch err:
		switch err:
			ErrAssert(e):
				print($"ErrAssert = {e}\n");
			anyerror(e):
				print($"anyerror = {e}\n");

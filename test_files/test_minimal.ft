use Core.print

data Data:
	i32 x;
	i32 y;
	Data(x, y);

interface Interface:
	def print();
	def inc();

func Func requires(Data d):
	def print():
		print($"d.(x, y) = {d.(x, y)}\n");

	def inc():
		d.(x, y) += (10, 10);

object Object implements(Interface):
	data: Data d;
	func: Func;
	Object(d);

def main():
	o := Object(Data(10, 20));
	o.inc();
	o.print();

	Func f = o;
	f.inc();
	f.print();

	Interface i = o;
	i.inc();
	i.print();

use Core.print

func IMove:
	def move();
	def print_pos();

data DPosition:
	i32x2 pos;
	DPosition(pos);

func FMovable requires(DPosition d):
	def move(i32 value):
		d.pos += value;

	def print_pos():
		print($"d.pos = {d.pos}\n");

entity Player:
	data: DPosition;
	func: IMove, FMovable;
	link:
		IMove::move -> FMovable::move,
		IMove::print_pos -> FMovable::print_pos;
	Player(DPosition);

def apply(mut IMove m):
	m.move();
	m.print_pos();

def main():
	p := Player(DPosition(i32x2(10, 20)));
	p.print_pos();
	apply(p);

use Core.print

data Data:
	i32 x;
	f32 y;
	Data(x, y);

func Func requires(Data d):
	def print():
		print($"d.(x, y) = ({d.x}, {d.y})\n");

def add(i32 x, i32 y) -> i32:
	return x + y;

def callable(i32 x) -> i32:
	return add(x, 10);

def main():
	d := Data(10, 3.14);
	Func.print(d);

	fn<mut Data> print_fn = Func::print;
	print_fn(d);

	fn<i32 -> i32> c = ::callable;
	print($"c(10) = {c(10)}\n");

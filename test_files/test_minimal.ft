use Core.print

enum State:
	S1, S2, S3;

def execute_next_phase():
	persistent State state = State.S1;
	switch state:
		S1:
			print("Executed State 1\n");
			state = State.S2;
		S2:
			print("Executed State 2\n");
			state = State.S3;
		S3:
			print("Executed State 3\n");
			state = State.S1;

def main():
	fn<> state_handler = ::execute_next_phase;
	for (_, _) in 0..6:
		state_handler();

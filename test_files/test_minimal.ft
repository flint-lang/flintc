use Core.print

data Data:
	i32 x;
	i32 y;
	Data(x, y);

interface Interface:
	def print();

func Func requires(Data d):
	def print():
		print($"d.(x, y) = {d.(x, y)}\n");

object Object implements(Interface):
	data: Data d;
	func: Func;
	Object(d);

def main():
	o := Object(Data(10, 20));
	o.print();

	Interface i = o;
	i.print();

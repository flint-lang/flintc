use Core.print

def main():
	u32x2 u_2 = (10, 20);
	print($"u_2 = {u_2}\n");
	u32x3 u_3 = (10, 20, 30);
	print($"u_3 = {u_3}\n");
	u32x4 u_4 = (10, 20, 30, 40);
	print($"u_4 = {u_4}\n");
	u32x8 u_8 = (10, 20, 30, 40, 50, 60, 70, 80);
	print($"u_8 = {u_8}\n");

	u64x2 u6_2 = (10, 20);
	print($"u6_2 = {u6_2}\n");
	u64x3 u6_3 = (10, 20, 30);
	print($"u6_3 = {u6_3}\n");
	u64x4 u6_4 = (10, 20, 30, 40);
	print($"u6_4 = {u6_4}\n");

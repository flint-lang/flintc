use Core.print

data Data1:
	i32 x;
	i32 y;
	Data1(x, y);

data Data2:
	i32 z;
	i32 w;
	Data2(z, w);

func Func requires(Data1 d):
	def fun():
		print("fun\n");

entity Entity:
	data:
		Data1 d1,
		Data2 d2;
	func: Func;
	Entity(d1, Func, d2);

	def print():
		print($"d1.(x, y) = {d1.(x, y)}, d2.(z, w) = {d2.(z, w)}\n");

def main():
	e := Entity(Data1(10, 20), Data2(30, 40));
	e.print();

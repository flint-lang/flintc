use Core.print

data Data1:
	i32 x;
	i32 y;
	Data1(x, y);

data Data2:
	i32 z;
	i32 w;
	Data2(z, w);

entity Entity:
	data:
		Data1 d1,
		Data2 d1;
	Entity(d1, d2);

	def print():
		print($"d1.(x, y) = {d1.(x, y)}, d2.(z, w) = {d2.(z, w)}\n");

def main():
	e := Entity(Data1(10, 20), Data2(30, 40));
	e.print();

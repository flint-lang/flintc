use Core.print

data Vec3:
	f32 x = 0.0;
	f32 y;
	f32 z = 0.0;
	Vec3(x, y, z);

entity Entity:
	data: Vec3 v;
	Entity(v);

	def add(Vec3 vec):
		v.(x, y, z) += vec.(x, y, z);

	def print():
		print($"v.(x, y, z) = {v.(x, y, z)}\n");

def main():
	v1 := Vec3(10, 20, 30);
	e := Entity(10);
	e.add(v1);
	e.print();

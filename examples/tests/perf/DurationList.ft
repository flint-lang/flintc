use Core.print
use Core.time

/// @brief A simple list of durations used for filtering etc in the profiling code
entity DurationList:
	data: DurationListHead;
	func: FDurationList;
	DurationList(DurationListHead);

/// @brief A single node in the duration list containing a single duration
///        and an optional next node
data DurationListNode:
	Duration duration;
	DurationListNode? next;
	DurationListNode(duration, next);

/// @brief The head of the 'DurationList' entity type required by
///        the duration list func type
data DurationListHead:
	DurationListNode? head;
	DurationListHead(head);

/// @brief A func module containing all functionality of the 'DurationList' entity type
func FDurationList requires(DurationListHead d):
	/// @brief Appends a new duration to the duration list
	///
	/// @param `duration` The duration to append
	def append(Duration duration):
		if d.head == none:
			d.head = DurationListNode(duration, none);
			return;
		DurationListNode? current = d.head;
		while current!.next != none:
			current = current!.next;
		current!.next = DurationListNode(duration, none);

	/// @brief Sorts all durations of the list in ascending order, smallest durations come first
	/// @note Just does a bubble-sort for now, it's good enough for now
	def sort():
		DurationListNode? start = d.head;
		while start != none:
			DurationListNode? current = start;
			while current!.next != none:
				const bool needs_swap = current!.duration.value > current!.next!.duration.value;
				if needs_swap:
					Duration temp = current!.duration;
					current!.duration = current!.next!.duration;
					current!.next!.duration = temp;
				current = current!.next;
			start = start!.next;

	/// @brief Prints this whole duration list
	def print():
		if d.head == none:
			print("List is empty\n");
			return;
		DurationListNode? current = d.head;
		print($"List (in ms): {as_unit(current!.duration, TimeUnit.MS)}");
		while current!.next != none:
			print(" -> ");
			current = current!.next;
			print(current!.duration.value);
			//print(as_unit(current!.duration, TimeUnit.MS));
		print("\n");

	/// @brief Calculates the length of the list
	///
	/// @return `u64` The length of the list
	def len() -> u64:
		if d.head == none:
			return 0;
		u64 len = 1;
		DurationListNode? current = d.head;
		while current!.next != none:
			current = current!.next;
			len++;
		return len;

	/// @brief Calculates the sum across all durations
	///
	/// @return `u64` The sum of all durations
	def sum() -> u64:
		if d.head == none:
			return 0;
		DurationListNode? current = d.head;
		u64 sum = current!.duration.value;
		while current!.next != none:
			current = current!.next;
			sum += current!.duration.value;
		return sum;

	/// @brief Returns the duration at the given index, returns 'none' if idx is out of bounds
	///
	/// @param `idx` The index to try to get the duration at
	/// @return `Duration?` The potential duration at the given index, 'none' if idx is out of bounds
	def at(u64 idx) -> Duration?:
		DurationListNode? current = d.head;
		for (i, _) in 0..idx:
			if current == none:
				return none;
			current = current!.next;
		return current!.duration;

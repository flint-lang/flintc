use Core.print
use Core.parse

def fasta(u32 n) -> str:
	str buffer = "";
	const u32 LINE_LEN = 60;
	const str ALU = "GGCCGGGCGCGGTGGCTCACGCCTGTAATCCCAGCACTTTGGGAGGCCGAGGCGGGCGGATCACCTGAGGTCAGGAGTTCGAGACCAGCCTGGCCAACATGGTGAAACCCCGTCTCTACTAAAAATACAAAAATTAGCCGGGCGTGGTGGCGCGCGCCTGTAATCCCAGCTACTCGGGAGGCTGAGGCAGGAGAATCGCTTGAACCCGGGAGGCGGAGGTTGCAGTGAGCCGAGATCGCGCCACTGCACTCCAGCCTGGGCGACAGAGCGAGACTCCGTCTCAAAAA";
	const str IUB_CODES = "ACGTBDHKMNRSVWY";
	const str IUB = "ACGT";

	// ONE: Homo sapiens alu
	buffer += ">ONE Homo sapiens alu\n";
	u32 todo = n;
	u64 j = 0;
	while todo > 0:
		u32 chunk = todo;
		if chunk > LINE_LEN:
			chunk = LINE_LEN;
		for (i, _) in 0..chunk:
			buffer += ALU[j % ALU.len];
			j++;
		buffer += '\n';
		todo -= chunk;
	
	// TWO: IUB ambiguity codes
	buffer += ">TWO IUB ambiguity codes\n";
	todo = n;
	j = 0;
	while todo > 0:
		u32 chunk = todo;
		if chunk > LINE_LEN:
			chunk = LINE_LEN;
		for (i, _) in 0..chunk:
			buffer += IUB_CODES[j % IUB_CODES.len];
			j++;
		buffer += '\n';
		todo -= chunk;
	
	// THREE: Homo sapiens frequency
	buffer += ">THREE Homo sapiens frequency\n";
	todo = n;
	j = 0;
	while todo > 0:
		u32 chunk = todo;
		if chunk > LINE_LEN:
			chunk = LINE_LEN;
		for (i, _) in 0..chunk:
			buffer += IUB[j % IUB.len];
			j++;
		buffer += '\n';
		todo -= chunk;
	return buffer;

def main(str[] args):
	u32 n = 1000;
	if args.len > 1:
		n = parse_u32(args[1]);
    print($"{fasta(n)}\n");

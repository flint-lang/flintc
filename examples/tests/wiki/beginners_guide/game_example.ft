use "../../../utils.ft"

test "0_spawning_window":
	str path = "tests/wiki/beginners_guide/game_example/0_spawning_window";
	str file = "main.ft";
	Config.compile_v_static = false;
	test_compiles_in(path, file, "--flags=\"-lraylib\"");
	Config.compile_v_static = true;


use "../../../utils.ft"

test "0_simple_object.ft":
	str path = "tests/wiki/beginners_guide/objects";
	str file = "0_simple_object.ft";
	test_file_ok($"{path}/{file}", "t.pos = (1.2, 3.4)\nt.pos = (1.74, 4.204)\nt.pos = (2.28, 5.008)\nt.pos = (2.82, 5.812)\nt.pos = (3.36, 6.616)\nt.pos = (3.9, 7.42)\n");

test "1_func_component.ft":
	str path = "tests/wiki/beginners_guide/objects";
	str file = "1_func_component.ft";
	test_file_ok($"{path}/{file}", "t.pos = (1.2, 3.4)\nt.pos = (1.74, 4.204)\n");

test "2_requiring_same_data_twice.ft":
	str path = "tests/wiki/beginners_guide/objects";
	str file = "2_requiring_same_data_twice.ft";
	test_file_fail($"{path}/{file}", "Parse Error at tests/wiki/beginners_guide/objects/2_requiring_same_data_twice.ft:8:33\nв””в”Җв”¬в”ӨE0000в”Ӯ\n8 в”Ӯ func MyFunc requires(MyData d1, MyData d2):\nв”Ңв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\nв”ңв”Җ Requiring the same type twice: MyData\nв””в”Җ Each required data type needs to be unique\n");

test "3_requiring_multiple_data.ft":
	str path = "tests/wiki/beginners_guide/objects";
	str file = "3_requiring_multiple_data.ft";
	test_file_ok($"{path}/{file}", "pos: (100, 100), size: (100, 100), dir: (3.3, 2.2)\npos: (133, 144), size: (100, 100), dir: (3.3, 2.2)\n");

test "4_pure_func_component.ft":
	str path = "tests/wiki/beginners_guide/objects";
	str file = "4_pure_func_component.ft";
	test_file_ok($"{path}/{file}", "x = 30\n");

test "5_composition.ft":
	str path = "tests/wiki/beginners_guide/objects";
	str file = "5_composition.ft";
	test_file_ok($"{path}/{file}", "Starting to run with my 4 legs with a speed of 30 km/h\nJumping 0.8m high with my 4 legs\n\nStarting to run with my 2 legs with a speed of 1.5 km/h\nJumping 0.1m high with my 2 legs\nStarting to fly for 100 seconds with my 10cm large wings\n");

test "6_encapsulation.ft":
	str path = "tests/wiki/beginners_guide/objects";
	str file = "6_encapsulation.ft";
	test_file_ok($"{path}/{file}", "pos: (100, 120), size: (200, 220)\no.pos = (100, 120)\n");


	str path = "tests/wiki/beginners_guide/objects";
	str file = "7_missing_data_fail.ft";
	test_file_fail($"{path}/{file}", "Parse Error at tests/wiki/beginners_guide/objects/7_missing_data_fail.ft:19:1\nв””в”Җв”Җв”¬в”ӨE0000в”Ӯ\n19 в”Ӯ object Object:\nв”Ңв”Җв”Җв”ҙв”Җв”ҳ\nв””в”Җ Object type is missing data 'Scale' required by func component 'FMove'\n");


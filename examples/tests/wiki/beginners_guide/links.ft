use "../../../utils.ft"

use Core.assert
use Core.system
use Core.filesystem

test "0_pure_interface.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "0_pure_interface.ft";
	test_file_ok($"{path}/{file}", "Hello, World!\n");

test "1_calling_virtual_function.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "1_calling_virtual_function.ft";
	test_file_fail($"{path}/{file}", "Parse Error at tests/wiki/beginners_guide/links/1_calling_virtual_function.ft:8:5\nв””в”Җв”¬в”ӨE0000в”Ӯ\n6 в”Ӯ def main():\n8 в”Ӯ В»   IMove.move();\nв”Ңв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ\nв””в”Җ Direct call of virtual function is not allowed\n");

test "2_virtual_instance_call.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "2_virtual_instance_call.ft";
	test_file_ok($"{path}/{file}", "Hello, World!\n");

test "3_including_interface_in_entity.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "3_including_interface_in_entity.ft";
	test_file_fail($"{path}/{file}", "Parse Error at tests/wiki/beginners_guide/links/3_including_interface_in_entity.ft:10:1\nв””в”Җв”Җв”¬в”ӨE0000в”Ӯ\n10 в”Ӯ entity Player:\nв”Ңв”Җв”Җв”ҙв”Җв”ҳ\nв””в”Җ Virtual function 'IMove.move' not linked to concrete function\n");

test "4_implementing_pure_interface.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "4_implementing_pure_interface.ft";
	test_file_fail($"{path}/{file}", "Parse Error at tests/wiki/beginners_guide/links/4_implementing_pure_interface.ft:18:1\nв””в”Җв”Җв”¬в”ӨE0000в”Ӯ\n18 в”Ӯ entity Player:\nв”Ңв”Җв”Җв”ҙв”Җв”ҳ\nв””в”Җ Virtual function 'IMove.print_pos' not linked to concrete function\n");

test "5_adding_links.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "5_adding_links.ft";
	test_file_ok($"{path}/{file}", "d.pos = (10, 20)\nd.pos = (20, 30)\n");

test "6_signature_mismatch.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "6_signature_mismatch.ft";
	test_file_fail($"{path}/{file}", "Parse Error at tests/wiki/beginners_guide/links/6_signature_mismatch.ft:22:9\nв””в”Җв”Җв”¬в”ӨE0000в”Ӯ\n18 в”Ӯ entity Player:\n21 в”Ӯ В»   link:\n22 в”Ӯ В»   В»   IMove::move -> FMovable::print_pos,\nв”Ңв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\nв””в”Җ Linking functions with different names is not allowed\n");

test "7_signature_mismatch_2.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "7_signature_mismatch_2.ft";
	test_file_fail($"{path}/{file}", "Parse Error at tests/wiki/beginners_guide/links/7_signature_mismatch_2.ft:22:9\nв””в”Җв”Җв”¬в”ӨE0000в”Ӯ\n18 в”Ӯ entity Player:\n21 в”Ӯ В»   link:\n22 в”Ӯ В»   В»   IMove::move -> FMovable::move,\nв”Ңв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\nв”ңв”Җ Linking functions with different explicit signatures is not allowed\nв”ңв”Җ Left signature: move() -> void {anyerror}\nв””в”Җ Right signature: move(const i32) -> void {anyerror}\n");

test "8_practical_example.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "8_practical_example.ft";
	test_file_ok($"{path}/{file}", "Drawing circle at [pos=(11, 2), r=5]\nDrawing rectangle at [pos=(10, 20), width=4, height=5\nDrawing circle at [pos=(3, 5), r=10]\nDrawing rectangle at [pos=(0, 0), width=4, height=2\n\nshapes[0].area() = 78\nshapes[1].area() = 20\nshapes[2].area() = 314\nshapes[3].area() = 8\nsum of areas = 420\n");

test "9_practical_example_2.ft":
	str path = "tests/wiki/beginners_guide/links";
	str file = "9_practical_example_2.ft";
	test_file_ok($"{path}/{file}", "Drawing circle at [pos=(11, 2), r=5]\nDrawing rectangle at [pos=(10, 20), width=4, height=5\nDrawing circle at [pos=(3, 5), r=10]\nDrawing rectangle at [pos=(0, 0), width=4, height=2\n\nshapes[0].area() = 78\nshapes[1].area() = 20\nshapes[2].area() = 314\nshapes[3].area() = 8\nsum of areas = 420\n");

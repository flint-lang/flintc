use Core.print

def add(i32 x, i32 y) -> i32:
    return x + y;

def sub(i32 x, i32 y) -> i32:
    return x - y;

def get_sub() -> fn<i32, i32 -> i32>:
    s := ::sub;
    return s;

def apply_op(fn<i32, i32 -> i32> op, i32 x, i32 y) -> i32:
    return op(x, y);

def main():
    fn<i32, i32 -> i32> op = ::add;
    i32 res = apply_op(op, 20, 10);
    print($"res = {res}\n");

    op = get_sub();
    res = apply_op(op, 20, 10);
    print($"res = {res}\n");
